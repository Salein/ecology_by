# Локально: Next и API на разных портах (uvicorn)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# За одним nginx (Docker compose): относительные запросы к тому же host, что у страницы
# NEXT_PUBLIC_API_URL=__RELATIVE__

# Vercel/Netlify: публичный HTTPS-URL API (часто ngrok / cloudflared → ваш ПК)
# NEXT_PUBLIC_API_URL=https://xxxx.ngrok-free.app
