# Скопируйте в .env в корне репозитория (рядом с docker-compose.yml). Файл .env в git не попадает.

# Порт nginx на хосте
# HTTP_PORT=8080

# Дополнительный origin (Vercel, свой домен туннеля) — добавится к CORS в API
# PUBLIC_ORIGIN=https://your-app.vercel.app
#
# Список origin для API (через запятую). По умолчанию в compose: localhost + 127.0.0.1 + regex *.trycloudflare.com
# CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# Отключить regex для quick tunnel (на проде): CORS_RELAX_TRY_TUNNEL=0
# Свой regex Origin: CORS_ORIGIN_REGEX=^https://...

# --- Cloudflare Tunnel ---
# Быстрый *.trycloudflare.com (профиль tunnel) — при старте можно NOTIFY_WEBHOOK_URL (POST JSON text/message).
# Локально 8080 и туннель: docker compose --profile tunnel up -d --build → http://localhost:8080 и ссылка из логов cloudflared
#
# Постоянный URL (профиль tunnel-token) — в .env именно TUNNEL_TOKEN=... (токен из Zero Trust при установке туннеля)
#   docker compose --profile tunnel down   # выключить quick tunnel, если был
#   docker compose --profile tunnel-token up -d --force-recreate cloudflared-token
#   PUBLIC_ORIGIN=https://ваш-статичный-хост   # для cookie/CORS

# --- Vercel + этот API через туннель ---
# PUBLIC_ORIGIN — см. выше; для cookie на другом домене:
# AUTH_COOKIE_SAMESITE=none
# AUTH_COOKIE_SECURE=1
# JWT_SECRET=не-короче-32-символов-для-hs256

# --- Optional LLM fallback for problematic PDF chunks ---
# Disabled by default. Uses OpenRouter only when deterministic parser returns 0 rows for a chunk/file.
# LLM_FALLBACK_ENABLED=0
# Shadow mode on by default: calls LLM and reports metrics, but does not write LLM rows to cache.
# LLM_FALLBACK_SHADOW_MODE=1
# OPENROUTER_API_KEY=your_openrouter_key
# LLM_FALLBACK_OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
# LLM_FALLBACK_MAX_CALLS_PER_IMPORT=60
# LLM_FALLBACK_CHUNK_RECORDS=2
# LLM_FALLBACK_TIMEOUT_SEC=20
# LLM_FALLBACK_MAX_RETRIES=2
