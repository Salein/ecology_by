# Скопируйте в .env и при необходимости измените (файл .env в git не попадает).
# BOOTSTRAP_OWNER_EMAIL=eug.kulish@gmail.com
# BOOTSTRAP_OWNER_PASSWORD=Bagamol42
# JWT_SECRET=свой-секрет-не-короче-32-символов-для-hs256
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ecology
# DATABASE_ECHO=0
# DATABASE_POOL_SIZE=10
# DATABASE_MAX_OVERFLOW=20
# NOMINATIM_TIMEOUT_SEC=3.0
# NOMINATIM_USER_AGENT=ecology/1.0 (обязательно свой контакт для публичного Nominatim)
# Свой сервер Nominatim — тогда можно REGISTRY_GEOCODE_DELAY_SEC=0
# NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
# Пауза между запросами при импорте (сек): не спим дольше, чем delay минус время HTTP
# REGISTRY_GEOCODE_DELAY_SEC=1.1
# REGISTRY_SEARCH_GEOCODE_BUDGET_SEC=8.0
# REGISTRY_SEARCH_GEOCODE_MAX=8
# DISTANCE_MODE=road
# OSRM_BASE_URL=https://router.project-osrm.org
# OSRM_TIMEOUT_SEC=2.5
# ROAD_DISTANCE_CANDIDATES=25

# --- Фронт на Vercel/Netlify, API локально через HTTPS-туннель ---
# Список origin фронта через запятую (обязательно совпадает с URL в браузере):
# CORS_ORIGINS=https://your-app.vercel.app,https://main--your-app.netlify.app
# Кросс-доменная сессия (обязательно вместе с HTTPS у API, см. DEPLOY-FRONT.md):
# AUTH_COOKIE_SAMESITE=none
# AUTH_COOKIE_SECURE=1

# Одноразовый импорт пользователей из JSON в PostgreSQL:
# python -m app.jobs.import_auth_users
#
# Миграции (из каталога server, venv активирован):
# python -m alembic upgrade head
